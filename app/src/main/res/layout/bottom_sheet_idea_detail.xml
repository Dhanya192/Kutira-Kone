<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:background="#CCCCCC"/>

    <!-- Icon + Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:background="@color/bg_primary">

        <ImageView
            android:id="@+id/ivIdeaIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvIdeaTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Face Mask"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="10dp"
            android:textAlignment="center"/>

        <TextView
            android:id="@+id/tvIdeaDifficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Easy"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp">

        <TextView
            android:id="@+id/tvIdeaDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description here"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.4"/>

        <TextView
            android:id="@+id/tvIdeaMaterials"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📦 Materials: Cotton"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="12dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvIdeaTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌱 Tip"
            android:textSize="12sp"
            android:textColor="@color/accent_green"
            android:layout_marginTop="12dp"
            android:background="#F1F8E9"
            android:padding="10dp"
            android:lineSpacingMultiplier="1.3"/>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIdeaClose"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Got it 👍"
                app:strokeColor="@color/divider"
                android:textColor="@color/text_secondary"
                app:cornerRadius="12dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIdeaFind"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔍 Find Materials"
                android:backgroundTint="@color/accent_orange"
                android:textColor="@color/white"
                app:cornerRadius="12dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
